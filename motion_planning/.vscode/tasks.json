{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/lib64/ccache/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Run Catch2 Tests",
            "type": "shell",
            "command": "cmake --build build --target run_tests && cd build && ctest --output-on-failure",
            "group": "test",
            "presentation": {
                "reveal": "silent", // Keeps terminal hidden unless a test fails
                "panel": "shared"
            }
        }
    ],
    "version": "2.0.0"
}